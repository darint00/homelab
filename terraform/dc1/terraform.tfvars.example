# Copy this file to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars — it contains secrets.

# --- Proxmox Connection ---
proxmox_endpoint  = "https://192.168.1.10:8006"
proxmox_api_token = "terraform@pam!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_insecure  = true
proxmox_ssh_user  = "root"
proxmox_node      = "pve"

# --- Talos & Cluster ---
talos_version = "v1.9.3"
cluster_name  = "dc1"

# VIP must be a free IP in the same subnet as the control plane, not assigned to any host.
cluster_vip = "192.168.1.100"

# --- Node IPs ---
controlplane_ip   = "192.168.1.101"
controlplane_cidr = 24
worker_ip         = "192.168.1.102"
worker_cidr       = 24
gateway           = "192.168.1.1"
dns_servers       = ["192.168.1.1", "1.1.1.1"]

# --- Proxmox Storage ---
vm_datastore     = "local-lvm"
vm_iso_datastore = "local"
vm_network_bridge = "vmbr0"

# --- VM IDs ---
controlplane_vmid = 300
worker_vmid       = 301

# --- Control Plane Sizing ---
controlplane_cpu_cores = 2
controlplane_memory    = 4096   # MB
controlplane_disk_size = 50     # GB

# --- Worker Sizing ---
worker_cpu_cores = 2
worker_memory    = 4096   # MB
worker_disk_size = 50     # GB
